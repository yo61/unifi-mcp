{
  "name": "@robinbowes/unifi-mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server for the UniFi Local Network Integration API.",
  "keywords": [
    "claude",
    "mcp",
    "model-context-protocol",
    "openapi",
    "ubiquiti",
    "unifi"
  ],
  "homepage": "https://github.com/yo61/unifi-mcp#readme",
  "bugs": {
    "url": "https://github.com/yo61/unifi-mcp/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yo61/unifi-mcp.git"
  },
  "bin": {
    "unifi-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "spec/integration.bundled.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "smoke": "pnpm build && node scripts/smoke.mjs",
    "update-spec": "node scripts/update-spec.mjs",
    "prepublishOnly": "pnpm verify && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@readme/openapi-parser": "6.2.1",
    "pino": "10.3.1",
    "undici": "8.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.5.3"
}
